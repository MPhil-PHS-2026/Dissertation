##Processing for eGFR

```{r exclude outlying creatinine values}
hist(creatinine_catchment$value, xlim = c(0, 500), breaks = 150) # work out where the outliers are

creatinine_catchment %>% 
  mutate(value = dplyr::if_else((value > 1 & value < 1000), 
                 value, 
                 NA)) %>% 
  filter(is.na(value) == TRUE) %>% 
  nrow() #check how many to see if this is reasonable

creatinine_catchment <- creatinine_catchment %>% 
  subset(value >1 & value < 1000) #check row difference is expected

```

```{r select most recent and second most recent creatinine values per patid}

#select earliest creatinine value
creatinine_eGFR <- creatinine_catchment %>% 
  group_by(patid) %>% 
  mutate(recent_obsdate = max(obsdate)) %>% 
  mutate(recent_binary = dplyr::if_else(recent_obsdate == obsdate,
                        1,
                        0)) %>% 
  mutate(recent_value = dplyr::if_else(recent_binary == 1, 
                                               value,
                                               NA))

creatinine_eGFR_recent <- creatinine_eGFR %>% 
  filter(recent_binary == 1) %>%  #only the most recent obsdates included
  arrange(recent_value) %>% 
  distinct(patid, .keep_all = TRUE)

creatinine_eGFR_2 <- creatinine_eGFR %>% 
  filter(recent_binary == 0) %>% 
  group_by(patid) %>% 
  mutate(second_recent_obsdate = max(obsdate)) %>% 
  mutate(second_recent_binary = dplyr::if_else(second_recent_obsdate == obsdate,
                        1,
                        0 )) %>% 
  mutate(second_recent_value = dplyr::if_else(second_recent_binary == 1,
                                                      value,
                                                      NA)) %>% 
  subset(select = c(patid, second_recent_obsdate, second_recent_binary, second_recent_value)) %>% 
    filter(second_recent_binary == 1) %>% 
  arrange(second_recent_value) %>% #keeping the lower cre value - check this with Duncan
  distinct(patid, .keep_all = TRUE) #check this code - I'm not sure I've handled the duplicates particularly well
  

creatinine_eGFR_recent_both <- left_join(creatinine_eGFR_recent, creatinine_eGFR_2, by = c("patid"))



```


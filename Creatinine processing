```{r create eGFR variable}
#merge datasets #why do I need to do this? I thought I'd already got most of this done
#eGFR <- left_join(creatinine_final, mortality_demog_final, by = c("patid")) # may include the other date with this if needs be (in mortality)
#Don't think I need to do this part 

#convert from creatinine e.

creatinine_final <- creatinine_final %>% 
  mutate(age_for_eGFR = case_when(obsdate_date_only < as.Date("2016-01-01") ~ age_in_2017 - 1.5, 
                                  obsdate_date_only >= as.Date("2016-01-01") ~ age_in_2017 - 0.5,
                                                                    )) #check this greatly 
eGFR <- creatinine_final %>% 
  mutate(eGFR_recent = 175 * (recent_value/88.4)^-1.154 * age_for_eGFR^-0.203 * ifelse(Phy_Sex == "Female", 0.742, 1)) %>% 
  mutate(eGFR_second_recent = 175 * (second_recent_value/88.4)^-1.154 * age_for_eGFR^-0.203 * ifelse(Phy_Sex == "Female", 0.742, 1)) #check these with Duncan - I'm not sold on this equation



```

```{r best of two eGFRs}

eGFR_main <- eGFR %>% 
  mutate(eGFR_best = if_else(eGFR_recent >= eGFR_second_recent | missing_second_binary == 1,
                             eGFR_recent,
                             eGFR_second_recent,
                             missing = NA))

```

```{r categorise eGFR}
#assigning the eGFR values to a category based on CKD scores
eGFR_main <- eGFR_main %>% 
  mutate(CKD_category = case_when(eGFR_best >= 60 ~ "Normal",
                                  (eGFR_best >= 45 & eGFR_best < 60 ~ "3a"),
                                  (eGFR_best >= 30 & eGFR_best < 45 ~ "3b"),
                                  (eGFR_best >= 15 & eGFR_best < 30 ~ "4"),
                                  eGFR_best < 15 ~ "5",
                                  missing_both_binary == 1 ~ "No data"))


eGFR_small <- eGFR_main %>% 
  subset(select = c(patid, hfd_date, CKD_category, age_in_2017, eGFR_best, eGFR_recent, eGFR_second_recent, missing_both_binary, missing_second_binary)) 
eGFR_small_long <- eGFR_small
save(eGFR_small_long, file = "eGFR_small_long.RData")
```



```{r categorise hyp}
#exclude outliers - sbp needs to be between 20 and 300. 
mortality_categorisation <- mortality_categorisation %>% 
  mutate(Phy_Sys__last = dplyr::if_else((Phy_Sys__last > 20 & Phy_Sys__last < 300), 
                 Phy_Sys__last, 
                 NA))

#categorise data - high, normal, no data
mortality_categorisation <- mortality_categorisation %>% 
  mutate(hyp_category_last = case_when(Pat_Hyp__in_last_year == "Y" | Phy_Sys__last > 140 ~ "High",
                                  Pat_Hyp__in_last_year == "N" & Phy_Sys__last <= 140 ~ "Normal",
                                  Pat_Hyp__in_last_year == "N" & is.na(Phy_Sys__last) == TRUE ~ "No data")) %>% 
  mutate(hyp_category_ever = case_when(Pat_Hyp__ever == "Y" | Phy_Sys__last > 140 ~ "High",
                                  Pat_Hyp__ever == "N" & Phy_Sys__last <= 140 ~ "Normal",
                                  Pat_Hyp__ever == "N" & is.na(Phy_Sys__last) == TRUE ~ "No data")) %>% 
  mutate(hyp_category_original = case_when(Phy_Sys__last > 140 ~ "High",
                                  Phy_Sys__last <= 140 ~ "Normal",
                                  is.na(Phy_Sys__last) == TRUE ~ "No data")) %>% #
  mutate(hyp_category = case_when(Phy_Sys__last > 140 ~ "High",
                                  Phy_Sys__last <= 140 & Phy_Sys__last >= 110 ~ "Normal",
                                  Phy_Sys__last < 110 ~ "Low",
                                  is.na(Phy_Sys__last) == TRUE ~ "No data")) 

```

```{r categorise BMI}
##Height and weight converted to BMI
#process height into metres

mortality_categorisation <- mortality_categorisation %>% 
  mutate(Phy_Hei__last = dplyr::if_else(Phy_Hei__last > 100 & Phy_Hei__last < 210, 
                                               Phy_Hei__last, 
                                               NA)) %>% 
  mutate(Phy_Hei__last = Phy_Hei__last / 100) %>% 
  mutate(Phy_Wei__last = dplyr::if_else(Phy_Wei__last > 25 & Phy_Wei__last < 500,
                                               Phy_Wei__last,
                                               NA))

#calculate extra BMI variables
mortality_categorisation <- mortality_categorisation %>% 
  mutate(Phy_BMI__last = case_when(is.na(Phy_BMI__last) == FALSE ~ Phy_BMI__last,
                                   is.na(Phy_BMI__last) == TRUE & is.na(Phy_Hei__last) == FALSE &
                                     is.na(Phy_Wei__last) == FALSE ~ 
                                     Phy_Wei__last/ (Phy_Hei__last ^ 2),
                                   is.na(Phy_BMI__last) == TRUE & (is.na(Phy_Hei__last) == TRUE | 
                                                                     is.na(Phy_Wei__last) == TRUE) ~ NA))

## Categorisation
#exclude outliers
mortality_categorisation <- mortality_categorisation %>% 
  mutate(Phy_BMI__last = dplyr::if_else((Phy_BMI__last > 10 & Phy_BMI__last < 80), 
                 Phy_BMI__last, 
                 NA))

#categorise data - underweight, normal weight, overweight, obese, no data
mortality_categorisation <- mortality_categorisation %>% 
  mutate(BMI_category_original = case_when(Phy_BMI__last < 18.5 ~ "Underweight",
                                  Phy_BMI__last < 25 & Phy_BMI__last >= 18.5 ~ "Normal weight",
                                  Phy_BMI__last < 30 & Phy_BMI__last >= 25 ~ "Overweight",
                                  Phy_BMI__last >= 30 ~ "Obese",
                                  is.na(Phy_BMI__last) == TRUE ~ "No data")) %>% 
  mutate(BMI_category = case_when(Phy_BMI__last < 18.5 ~ "Underweight",
                                  Phy_BMI__last < 25 & Phy_BMI__last >= 18.5 ~ "Normal weight",
                                  Phy_BMI__last < 30 & Phy_BMI__last >= 25 ~ "Overweight",
                                  Phy_BMI__last < 35 & Phy_BMI__last >= 30 ~ "Obesity 1",
                                  Phy_BMI__last < 40 & Phy_BMI__last >= 35 ~ "Obesity 2", 
                                  Phy_BMI__last >= 40 ~ "Obesity 3",
                                  is.na(Phy_BMI__last) == TRUE ~ "No data"))
table(mortality_categorisation$BMI_category)
  

```


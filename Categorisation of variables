``` {r categorise HbA1c/DM}

summary(mortality$Blo_HBA1C__last)
#exclude outliers - HbA1c between 1 and 150, no need to exclude on diagnosis
mortality_categorisation <- mortality %>% 
 mutate(Blo_HBA1C__last = dplyr::if_else((Blo_HBA1C__last > 1 & Blo_HBA1C__last < 150), 
                 Blo_HBA1C__last, 
                 NA))
#categorise data - controlled, uncontrolled, no diagnosis

mortality_categorisation <- mortality_categorisation %>% 
  mutate(DM_category = case_when(Pat_DM__ever == "Y" & Blo_HBA1C__last < 58 ~ "DM_controlled",
                                 Pat_DM__ever == "Y" & Blo_HBA1C__last >= 58 ~ "DM_uncontrolled",
                                 Pat_DM__ever == "Y" & is.na(Blo_HBA1C__last == TRUE) ~ "DM no data",
                                 Pat_DM__ever == "N" ~ "No_diagnosis")) %>% 
  mutate(DM_category_2 = case_when(Pat_DM__ever == "Y" & Blo_HBA1C__last < 58 ~ "DM_controlled",
                                 Pat_DM__ever == "Y" & Blo_HBA1C__last >= 58 & Blo_HBA1C__last < 120 ~ "DM_uncontrolled",
                                 Pat_DM__ever == "Y" & Blo_HBA1C__last >= 120 ~ "DM_very_uncontrolled",
                                 Pat_DM__ever == "Y" & is.na(Blo_HBA1C__last == TRUE) ~ "DM no data",
                                 Pat_DM__ever == "N" & Blo_HBA1C__last < 58 ~ "No_diagnosis",
                                 Pat_DM__ever == "N" & Blo_HBA1C__last >= 58 ~ "No_diagnosis_raised",
                                 Pat_DM__ever == "N" & is.na(Blo_HBA1C__last) == TRUE ~ "No_diagnosis no data"))
table(mortality_categorisation$DM_category)         
```


```{r categorise Hb}
#exclude outliers - No missing data on Sex - everyone is classed as Male and Female, haemoglobin between 1 and 40
mortality_categorisation <- mortality_categorisation %>% 
  mutate(Blo_Hb__last = dplyr::if_else((Blo_Hb__last > 1 & Blo_Hb__last < 40), 
                 Blo_Hb__last, 
                 NA))

#categorise data - normal, low, no data
mortality_categorisation <- mortality_categorisation %>% 
  mutate(Hb_category = case_when((Phy_Sex == "Female" & Blo_Hb__last >= 12) | (Phy_Sex == "Male" & Blo_Hb__last >= 13) ~ "Normal",
                                 (Phy_Sex == "Female" & Blo_Hb__last < 12) | (Phy_Sex == "Male" & Blo_Hb__last < 13) ~ "Low",
                                 is.na(Blo_Hb__last) == TRUE ~ "No data"))
table(mortality_categorisation$Hb_category)
```

```{r categorise Alb}
